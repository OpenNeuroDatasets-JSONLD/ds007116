    "ales_frequency": {
        "LongName": "ales_frequency_score",
        "Description": "Global score comprised of the sum of 'yes' responses to whether an event occured in item-level responses. n/a if one of the individual item responses is n/a.",
        "Derivative": true
    },
    "ales_severity_sum": {
        "LongName": "ales_severity_sum",
        "Description": "Global score comprised of the sum of responses to items asking how much the event affected the participant (_1 in questions 1-11, _2 in questions 12-25). n/a if any one of the individual item responses is n/a AND the event was endorsed.",
        "Derivative": true
    },
    "ales_severity_mean": {
        "LongName": "ales_severity_mean",
        "Description": "Global score comprised of the mean of responses to items asking how much the event affected the participant (_1 in questions 1-11, _2 in questions 12-25). n/a if any one of the individual item responses is n/a AND the event was endorsed.",
        "Derivative": true
    },
    "ales_good_count": {
        "LongName": "ales_good_count",
        "Description": "Global score comprised of the sum of 'mostly good' (1) responses to items asking whether the event was a good or bad experience (12_2 through 25_2). 'Not applicable' or 'don't know' responses were not counted in either good_count or bad_count scores. n/a if any one of the individual item responses is n/a AND the event was endorsed.",
        "Derivative": true
    },
    "ales_bad_count": {
        "LongName": "ales_bad_count",
        "Description": "Global score comprised of the sum of 'mostly bad' (2) responses to items asking whether the event was a good or bad experience (12_2 through 25_2). 'Not applicable' or 'don't know' responses were not counted in either good_count or bad_count scores. n/a if any one of the individual item responses is n/a AND the event was endorsed.",
        "Derivative": true
    }

